import { z } from "zod";
import { useAppForm } from "@/components/_form";

const schema = z.object({
  // name: z.string({ required_error: "Error message" })
});

export const use<%= formName %> = () => {
  const form = useAppForm({
    validators: {
      onSubmit: schema,
    },
    defaultValues: {
      // name: "",
    } as z.infer<typeof schema>,
    onSubmit: ({ value }) => {}
  });

  return {
    form
  };
};
